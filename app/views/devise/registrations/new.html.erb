<%= render layout: "devise/shared/auth_layout" do %>
  <%= form_for(resource,
      as: resource_name,
      url: registration_path(resource_name),
      html: {
        class: "auth-form",
        data: { turbo: false }
      }) do |f| %>

    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="auth-field">
      <%= f.label :account_name, class: "auth-label" %>
      <%= f.text_field :account_name, class: "auth-input" %>
    </div>

    <div class="auth-field">
      <%= f.label :email, class: "auth-label" %>
      <%= f.email_field :email, class: "auth-input" %>
    </div>

    <div class="auth-field">
      <%= f.label :password, class: "auth-label" %>
      <%= f.password_field :password, class: "auth-input" %>
    </div>

    <div class="auth-field">
      <%= f.label :password_confirmation, class: "auth-label" %>
      <%= f.password_field :password_confirmation, class: "auth-input" %>
    </div>

    <div class="auth-links">
      <%= render "devise/shared/links" %>
    </div>

    <div class="auth-actions">
      <%= f.submit "CREATE ACCOUNT", class: "auth-button" %>
    </div>
  <% end %>
<% end %>
