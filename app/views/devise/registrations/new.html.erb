<div class="auth-page">
  <%= image_tag "devise-photo.jpg", class: "auth-image" %>

  <div class="auth-body">
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="auth-field">
        <%= f.label :account_name, class: "auth-label" %>
        <%= f.text_field :account_name, autofocus: true, autocomplete: "username", class: "auth-input" %>
      </div>

      <div class="auth-field">
        <%= f.label :email, class: "auth-label" %>
        <%= f.email_field :email, autocomplete: "email", class: "auth-input" %>
      </div>

      <div class="auth-field">
        <%= f.label :password, class: "auth-label" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "auth-input" %>
      </div>

      <div class="auth-field">
        <%= f.label :password_confirmation, class: "auth-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "auth-input" %>
      </div>

      <div class="auth-links">
        <%= render "devise/shared/links" %>
      </div>

      <div class="auth-actions">
        <%= f.submit "CREATE ACCOUNT", class: "auth-button" %>
      </div>
    <% end %>
  </div>
</div>
