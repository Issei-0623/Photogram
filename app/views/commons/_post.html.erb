<article class="feed-post-card">
  <%= render "posts/post_author", post: post, user: post.user %>

  <%= link_to post_path(post), class: "feed-post-image-link" do %>
    <%= render "posts/post_images_preview", post: post %>
  <% end %>

  <%= render "posts/post_actions",
        post: post,
        comment_path: post_path(post, anchor: "comment_section"),
        liked: local_assigns.fetch(:liked_post_ids, Set.new).include?(post.id) %>

  <%= render "posts/post_content", post: post %>
</article>
