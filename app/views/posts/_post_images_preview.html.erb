<% if post.images.attached? %>
  <div class="post-images-grid">
    <% post.images.first(3).each_with_index do |image, index| %>
      <div class="image-wrapper">
        <%= image_tag image.variant(resize_to_fill: [150, 150]).processed %>

        <% if index == 2 && post.images.size > 3 %>
          <div class="overlay">
            +<%= post.images.size - 3 %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>