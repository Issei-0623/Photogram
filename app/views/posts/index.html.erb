<div class="feed-page">
  <header class="feed-header">
    <%= link_to new_post_path, class: "feed-header-icon" do %>
      <%= image_tag "photo-camera.png", alt: "新規投稿" %>
    <% end %>

    <details class="feed-title-menu">
      <summary class="feed-title">Photogram</summary>

      <div class="feed-menu">
        <%= link_to "全体の投稿", posts_path, class: "feed-menu-item" %>
        <%= link_to "タイムライン", posts_path(type: "timeline"), class: "feed-menu-item" %>
      </div>
    </details>

    <details class="feed-settings-menu">
      <summary class="feed-header-icon">
        <%= image_tag "setting.png", alt: "設定" %>
      </summary>

      <div class="feed-menu feed-menu--right">
        <%= link_to "プロフィール編集", user_path(current_user), class: "feed-menu-item" %>
        <%= link_to "ログアウト",
              destroy_user_session_path,
              data: { turbo_method: :delete },
              class: "feed-menu-item feed-menu-item--danger" %>
      </div>
    </details>
  </header>

  <main class="feed-posts">
    <% if params[:type] == "timeline" %>
      <% if current_user.followings.any? %>
        <% if @popular_posts.any? %>
          <section class="feed-section">
            <h2 class="feed-section-title">人気投稿</h2>

            <% @popular_posts.each do |post| %>
              <%= render "commons/post", post: post %>
            <% end %>
          </section>
        <% end %>

        <section class="feed-section">
          <h2 class="feed-section-title">タイムライン</h2>

          <% if @posts.any? %>
            <% @posts.each do |post| %>
              <%= render "commons/post", post: post %>
            <% end %>
          <% else %>
            <div class="feed-empty">
              <p>フォロー中ユーザーの投稿はまだありません。</p>
            </div>
          <% end %>
        </section>
      <% else %>
        <div class="feed-empty">
          <p>フォローしているユーザーがいません。</p>
          <p>ユーザーをフォローすると投稿が表示されます。</p>
        </div>
      <% end %>
    <% else %>
      <% if @recent_posts.any? %>
        <% @recent_posts.each do |post| %>
          <%= render "commons/post", post: post %>
        <% end %>
      <% else %>
        <div class="feed-empty">
          <p>投稿はまだありません。</p>
        </div>
      <% end %>
    <% end %>
  </main>
</div>