<div class="feed-page" data-controller="accordion-menu">
  <%= render "feed_header" unless turbo_frame_request? %>

  <%= render "feed_posts",
        timeline: params[:type] == "timeline",
        posts: @posts,
        popular_posts: @popular_posts,
        recent_posts: @recent_posts,
        liked_post_ids: @liked_post_ids,
        has_next_page: @has_next_page,
        next_cursor: @next_cursor %>
</div>
