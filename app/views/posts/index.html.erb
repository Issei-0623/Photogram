<h1>投稿一覧</h1>

<% @posts.each do |post| %>
  <% if post.user.avatar.attached? %>
    <%= image_tag post.user.avatar.variant(resize_to_fill: [50, 50]).processed %>
  <% else %>
    <%= image_tag "default_avatar.png", size: "50x50" %>
  <% end %>

  <p><%= post.user.account_name %></p>
  <p><%= post.created_at.strftime("%Y/%m/%d %H:%M") %></p>
  <p><%= post.content %></p>

  <% if post.images.attached? %>
    <% post.images.each do |image| %>
      <%= image_tag image.variant(resize_to_fill: [100, 100]).processed %>
    <% end %>
  <% end %>
<% end %>

<%= link_to '新投稿', new_post_path %>