<div class="post-edit-page">
  <header class="post-show-header">
    <%= link_to "←", post_path(@post), class: "post-show-back" %>
    <p class="post-show-title">Edit</p>
    <span class="post-show-menu-placeholder"></span>
  </header>

  <%= form_with model: @post, local: true, class: "post-edit-form" do |f| %>
    <% if @post.errors.any? %>
      <div class="status-errors">
        <% @post.errors.full_messages.each do |message| %>
          <p><%= message %></p>
        <% end %>
      </div>
    <% end %>

    <%= f.text_area :content,
          class: "status-textfield post-edit-textarea",
          placeholder: "What's on your mind ?" %>

    <%= f.submit "更新", class: "post-edit-submit" %>
  <% end %>
</div>