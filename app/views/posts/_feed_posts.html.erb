<main class="feed-posts" id="feed_posts">
  <% if timeline %>
    <% if current_user.followings.any? %>
      <% if params[:before].blank? && popular_posts.any? %>
        <section class="feed-section">
          <h2 class="feed-section-title">人気投稿</h2>

          <% popular_posts.each do |post| %>
            <%= render "commons/post", post: post, liked_post_ids: liked_post_ids %>
          <% end %>
        </section>
      <% end %>

      <section class="feed-section">
        <% if params[:before].blank? %>
          <h2 class="feed-section-title">タイムライン</h2>
        <% end %>

        <% if posts.any? %>
          <%= render "post_items", posts: posts, liked_post_ids: liked_post_ids %>
        <% else %>
          <div class="feed-empty">
            <p>フォロー中ユーザーの投稿はまだありません。</p>
          </div>
        <% end %>
      </section>
    <% else %>
      <div class="feed-empty">
        <p>フォローしているユーザーがいません。</p>
        <p>ユーザーをフォローすると投稿が表示されます。</p>
      </div>
    <% end %>
  <% else %>
    <% if recent_posts.any? %>
      <%= render "post_items", posts: recent_posts, liked_post_ids: liked_post_ids %>
    <% else %>
      <div class="feed-empty">
        <p>投稿はまだありません。</p>
      </div>
    <% end %>
  <% end %>
</main>

<%= render "feed_pagination",
      has_next_page: has_next_page,
      next_cursor: next_cursor,
      timeline: timeline %>