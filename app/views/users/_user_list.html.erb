<% if users.any? %>
  <div class="user-list">
    <% users.each do |user| %>
      <div class="user-list-item">
        <%= link_to user_path(user), class: "user-list-link" do %>
          <div class="user-list-avatar">
            <%= render "commons/avatar",
              user: user,
              class_name: nil,
              size: [80, 80] %>

          </div>

          <div class="user-list-info">
            <p class="user-list-name"><%= user.account_name %></p>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="user-list-empty">ユーザーはいません。</p>
<% end %>
